# ─────────────────────────────────────────────────────────────
#  TELEGRAM BOT TOKENLARI (BotFather'dan olinadi)
# ─────────────────────────────────────────────────────────────
# Sotuv bot — mijozlar zakaz beradigan bot
BOT_CUSTOMER_TOKEN=
# Admin bot — buyurtmalarni qabul/tasdiqlash va katalog boshqaruvi
BOT_ADMIN_TOKEN=
# Super Admin bot — do'konni sozlash va analiz
BOT_SUPERADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────
#  ROLLAR (Telegram ID lar, vergul bilan ajratilgan)
# ─────────────────────────────────────────────────────────────
# Super adminlar (do'kon egasi) — Super Admin botga faqat shular kira oladi
SUPERADMIN_IDS=123456789
# Adminlar/operatorlar — Admin botga kira oladiganlar (super adminlar avtomatik admin)
ADMIN_IDS=

# ─────────────────────────────────────────────────────────────
#  MA'LUMOTLAR BAZASI (Railway Postgres avtomatik DATABASE_URL beradi)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=
# Yoki lokal uchun qismlarga ajratib:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maxsulot_bot
DB_USER=postgres
DB_PASS=

# ─────────────────────────────────────────────────────────────
#  MINI APP / WEBAPP
# ─────────────────────────────────────────────────────────────
# Mini App ochiladigan public URL (Railway domeni). Bo'sh bo'lsa Railway domeni avtomatik olinadi.
WEBAPP_URL=
PUBLIC_BASE_URL=

# Xavfsizlik: faqat Telegram orqali ochilgan (initData bilan tasdiqlangan) so'rovlar
STRICT_AUTH=true
INITDATA_MAX_AGE=86400
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60

# Vaqt mintaqasi
TIMEZONE=Asia/Tashkent
